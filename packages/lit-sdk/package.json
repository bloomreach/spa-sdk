{
  "name": "@bloomreach/lit-sdk",
  "version": "27.2.0",
  "description": "Bloomreach SPA SDK for Lit web components",
  "keywords": [
    "bloomreach",
    "sdk",
    "lit",
    "web-components"
  ],
  "author": "Bloomreach B.V.",
  "license": "Apache-2.0",
  "homepage": "https://www.bloomreach.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bloomreach/spa-sdk",
    "directory": "packages/lit-sdk"
  },
  "bugs": {
    "url": "https://bloomreach.atlassian.net/projects/SPASDK/issues"
  },
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.umd.cjs"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "lit": "^3.2.0",
    "@lit/context": "^1.1.0"
  },
  "dependencies": {
    "@bloomreach/spa-sdk": "27.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.31.0",
    "jsdom": "^26.0.0",
    "lit": "^3.2.0",
    "@lit/context": "^1.1.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
